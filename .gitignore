# ====== Estado da janela do Obsidian (específico da máquina) ======
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# ====== Cache/estado temporário ======
.obsidian/cache/
.trash/
.DS_Store
Thumbs.db
desktop.ini
.gitignore

# ====== Arquivos temporários / credenciais (NUNCA versionar) ======
token.md
*.token
*_token.txt
token_temp.*

# Ignorar arquivos grandes
*.dwg
*.pdf
*.mp4
*.zip
*.exe

# Mas permitir PDFs importantes (exceção)
!relatorios/*.pdf

